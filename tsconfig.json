{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS", 
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true, 
    "noEmit": false 
  },
  "include": [
    "src/server.ts",  
    "src/chess.ts",   
    "src/chessGame.ts",  
    "src/types.ts", 
  ],
  "exclude": ["node_modules"]
}